# Hermes Doctor v0.1.3 环境变量示例
# 复制此文件为 .env 并填入真实值（不要提交 .env）
# 体检脚本会检测 .env 是否存在，不会读取其内容

# 飞书机器人凭据（可选，仅在飞书路由场景需要）
# FEISHU_APP_ID=cli_xxxxxxxxxxxx
# FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格 Base ID（多维表格写入需要）
# FEISHU_BITABLE_APP_TOKEN=xxxxxxxxxxxxxxxx

# 日志级别（默认 INFO）
# HERMES_DOCTOR_LOG_LEVEL=DEBUG
